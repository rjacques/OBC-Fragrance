      title: "Gift shopper",
      customer: "I need a gift, but I do not know what kind of scent they like.",
      response:
        "Start with a mood question, then lead with a 50ml option if the customer is still unsure.",
    },
    {
      title: "Everyday shopper",
      customer: "I want something clean and easy to wear every day.",
      response:
        "Start with Star Dust, then show Milky Cloud if they want something softer and more comforting.",
    },
    {
      title: "Evening shopper",
      customer: "I want something richer for evening.",
      response:
        "Choose between warm, elegant, or bold first, then compare one clear option against one backup.",
    },
  ],
};
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Module 1 | O Beauty Co - Fragrance</title>
  </head>
  <body class="bg-[#f4f1ed] text-[#27211c]">
    <main class="mx-auto max-w-[1240px] px-3 py-3 md:px-6 md:py-6">
      <header class="sticky top-3 z-30 rounded-[0.9rem] border border-[#e6dfd8] bg-white/94 px-3 py-3 shadow-[0_10px_26px_rgba(56,37,24,0.05)] backdrop-blur md:px-6">
        <div class="flex items-center justify-between gap-4 md:hidden">
          <div class="flex min-w-0 items-center gap-3">
            <img src={tfgLogoUrl} alt="TFG logo" class="h-10 w-10 shrink-0" loading="eager" />
            <p class="min-w-0 text-sm font-medium leading-5 text-[#51463d]">{courseTitle}</p>
          </div>

          <details class="relative shrink-0 md:hidden" data-mobile-nav>
            <summary class="flex h-11 w-11 cursor-pointer list-none items-center justify-center rounded-full border border-[#e8e0d8] bg-[#faf8f6] text-[#51463d] transition hover:bg-[#f4efea] [&::-webkit-details-marker]:hidden">
              <span class="sr-only">Toggle lesson navigation</span>
              <span aria-hidden="true" class="flex flex-col gap-[0.28rem]">
                <span class="block h-[2px] w-5 rounded-full bg-current"></span>
                <span class="block h-[2px] w-5 rounded-full bg-current"></span>
                <span class="block h-[2px] w-5 rounded-full bg-current"></span>
              </span>
            </summary>

            <div class="absolute right-0 top-[calc(100%+0.75rem)] z-20 w-64 max-w-[calc(100vw-1.5rem)] overflow-hidden rounded-[0.9rem] border border-[#e6dfd8] bg-white p-2 shadow-[0_14px_36px_rgba(56,39,27,0.09)]">
              <div class="flex flex-col gap-1.5 text-sm text-[#51463d]">
                {navItems.map((item) => (
                  <a href={item.href} class="rounded-[0.75rem] px-4 py-3 transition hover:bg-[#f4efea]" data-mobile-nav-link>{item.label}</a>
                ))}
              </div>
            </div>
          </details>
        </div>

        <div class="hidden md:flex md:items-center md:justify-between md:gap-6">
          <div class="flex items-center gap-4">
            <img src={tfgLogoUrl} alt="TFG logo" class="h-10 w-10" loading="eager" />
            <p class="text-sm font-medium text-[#51463d]">{courseTitle}</p>
          </div>
          <div class="flex flex-wrap gap-2 text-sm text-[#51463d]">
            {navItems.map((item) => (
              <a href={item.href} class="rounded-full border border-[#e8e0d8] bg-[#faf8f6] px-4 py-2 hover:bg-[#f4efea]">{item.label}</a>
            ))}
          </div>
        </div>
      </header>

      <section class="relative mt-4 overflow-hidden rounded-[1rem] border border-[#e3ddd7] shadow-[0_14px_36px_rgba(56,39,27,0.05)]">
        <img
          src={courseHeroImage.src}
          width={courseHeroImage.width}
          height={courseHeroImage.height}
          alt=""
          aria-hidden="true"
          class="absolute inset-0 h-full w-full object-cover"
          style="object-position: center 58%;"
        />
        <div class="absolute inset-0 bg-[linear-gradient(90deg,#f6f1ec_0%,#f6f1ec_44%,rgba(255,255,255,0.66)_66%,rgba(255,255,255,0.03)_100%)]"></div>
        <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(255,255,255,0.26)_0%,rgba(255,255,255,0.08)_100%)]"></div>
        <div class="absolute right-[-4rem] top-[-3rem] h-48 w-48 rounded-full bg-white/45 blur-2xl"></div>
        <div class="absolute bottom-[-5rem] right-20 h-56 w-56 rounded-full bg-[#d7bca8]/26 blur-2xl"></div>
        <div class="relative px-4 py-10 md:px-10 md:py-20 lg:px-12 lg:py-24">
          <img src={OBC_LOGO} alt="Beauty Co. logo" class="h-[4.8rem] w-auto md:h-24" />
          <div class="mt-6 inline-flex items-center gap-3 rounded-full border border-[#e6ddd5] bg-white/88 px-4 py-2 backdrop-blur md:mt-8">
            <span class="text-xs font-semibold uppercase tracking-[0.22em] text-[#8f7968]">Module 1</span>
          </div>
          <h1 class="hero-title mt-10 max-w-xl font-semibold tracking-[-0.03em] text-[#2f2924] md:mt-12">{courseTitle}</h1>
          <p class="body-copy mt-4 max-w-xl text-[#51463d]">{courseSubtitle}</p>
        </div>
      </section>

      <section
        id="range"
        class="mt-6 overflow-hidden rounded-[1rem] border shadow-[0_14px_36px_rgba(56,39,27,0.05)]"
        style="border-color: #d8b9a7; background: linear-gradient(180deg, #f7f1eb 0%, #fff 24%, #fff 100%);"
      >
        <div class="bg-[linear-gradient(135deg,#f4efea_0%,#d2b7a6_100%)] px-4 py-8 md:px-8">
          <p class="text-sm font-semibold uppercase tracking-[0.18em] text-[#6e6054]">{rangeOverview.lesson}</p>
          <h2 class="section-title mt-3 font-semibold tracking-[-0.03em] text-[#2f2924]">{rangeOverview.title}</h2>
        </div>
        <div class="space-y-6 px-4 py-6 md:px-8 md:py-8">
          <div class="rounded-[0.95rem] border border-[#e7dfd8] bg-white p-5">
            <div class="body-copy space-y-4 text-[#4e4741]">
              {rangeOverview.summary.map((paragraph) => <p>{paragraph}</p>)}
            </div>
          </div>

          <div class="grid gap-4 md:grid-cols-2">
            {rangeOverview.cards.map((card) => (
              <article class="rounded-[0.95rem] border border-[#eaded4] bg-[linear-gradient(180deg,rgba(255,255,255,0.95)_0%,#fff6f1_100%)] p-5 shadow-[0_10px_24px_rgba(56,39,27,0.035)]">
                <h3 class="section-title font-semibold tracking-[-0.02em] text-[#2f2924]">{card.title}</h3>
                <ul class="body-list mt-4 list-disc space-y-2 pl-5 text-[#4e4741] marker:text-[#605248]">
                  {card.bullets.map((bullet) => <li>{formatBulletText(bullet)}</li>)}
                </ul>
              </article>
            ))}
          </div>

          <div class="grid gap-4 md:grid-cols-[minmax(0,1.1fr)_minmax(0,0.9fr)]">
            <article class="rounded-[0.95rem] border border-[#c9bfaa] p-5" style="background: linear-gradient(135deg, rgba(255,255,255,0.96) 0%, #d2b7a626 100%);">
              <h3 class="section-title font-semibold tracking-[-0.02em] text-[#2f2924]">Opening questions</h3>
              <ul class="body-list mt-4 list-disc space-y-2 pl-5 text-[#4e4741] marker:text-[#605248]">
                {rangeOverview.openingQuestions.map((question) => <li>{formatBulletText(question)}</li>)}
              </ul>
            </article>
            <article class="rounded-[0.95rem] border border-transparent p-5 text-white" style="background: linear-gradient(135deg, #8d7260 0%, #d2b7a6 100%);">
              <p class="inline-flex rounded-full bg-white/18 px-4 py-2 text-sm font-semibold">{rangeOverview.scenario.title}</p>
              <p class="body-copy mt-4 text-white/95"><strong>Customer:</strong> {rangeOverview.scenario.customer}</p>
              <p class="body-copy mt-4 text-white/95"><strong>Best response:</strong> {rangeOverview.scenario.response}</p>
            </article>
          </div>
        </div>
      </section>

      {families.map((family) => (
        <section
          id={family.id}
          class="mt-6 overflow-hidden rounded-[1rem] border shadow-[0_14px_36px_rgba(56,39,27,0.05)]"
          style={`border-color: ${family.accent}66; background: linear-gradient(180deg, ${family.soft} 0%, #fff 22%, #fff 100%);`}
        >
          <div class="relative overflow-hidden px-4 py-8 md:px-8">
            {family.headerBanner ? (
              <>
                <img
                  src={family.headerBanner.image.src}
                  width={family.headerBanner.image.width}
                  height={family.headerBanner.image.height}
                  alt={family.headerBanner.alt}
                  aria-hidden="true"
                  class="absolute inset-0 h-full w-full object-cover"
                  style={`object-position: ${family.headerBanner.position};`}
                />
                <div
                  class="absolute inset-0"
                  style={`background: linear-gradient(90deg, ${family.soft} 0%, ${family.soft} 46%, rgba(255,255,255,0.94) 70%, rgba(255,255,255,0.16) 100%);`}
                ></div>
              </>
            ) : (
              <div class="absolute inset-0" style={`background: linear-gradient(135deg, ${family.soft} 0%, ${family.accent} 100%);`}></div>
            )}
            <div class="relative">
              <p class="text-sm font-semibold uppercase tracking-[0.18em] text-[#6e6054]">{family.lesson}</p>
              <h2 class="section-title mt-3 font-semibold tracking-[-0.03em] text-[#2f2924]">{family.title}</h2>
            </div>
          </div>

          <div class="space-y-6 px-4 py-6 md:px-8 md:py-8">
            <div class="rounded-[0.95rem] border p-5" style={`border-color: ${family.accent}40; background: linear-gradient(135deg, rgba(255,255,255,0.98) 0%, ${family.soft} 100%);`}>
              <div class="body-copy space-y-4 text-[#4e4741]">
                {family.summary.map((paragraph) => <p>{paragraph}</p>)}
              </div>
            </div>

            <div class="grid gap-4">
              {family.scents.map((scent) => (
                <article
                  class="overflow-hidden rounded-[0.95rem] border shadow-[0_10px_24px_rgba(56,39,27,0.035)]"
                  style={`border-color: ${family.accent}2f; background: linear-gradient(180deg, rgba(255,255,255,0.98) 0%, ${family.soft} 100%);`}
                >
                  <div class="px-5 pt-5">
                    <p class="tiny-label text-[#7a6b60]">{scent.storyTitle}</p>
                    <h3 class="product-title mt-3 font-semibold tracking-[-0.02em] text-[#2f2924]">{scent.name}</h3>
                  </div>
                  <div class={`${scent.productImage || scent.visualFallback ? "md:grid md:grid-cols-[252px_minmax(0,1fr)] md:items-start lg:grid-cols-[272px_minmax(0,1fr)]" : ""}`}>
                    {(scent.productImage || scent.visualFallback) && (
                      <div class="product-media p-4 pt-4 md:p-5">
                        {scent.productImage ? (
                          <div class="product-image-frame w-full overflow-hidden rounded-[0.8rem] bg-white">
                            <img
                              src={scent.productImage.image.src}
                              width={scent.productImage.image.width}
                              height={scent.productImage.image.height}
                              alt={scent.productImage.alt}
                              class="h-full w-full object-cover object-center"
                              loading="lazy"
                            />
                          </div>
                        ) : (
                          <div
                            class="product-image-frame relative w-full overflow-hidden rounded-[0.8rem]"
                            style={`background: linear-gradient(135deg, ${family.soft} 0%, ${family.accent} 100%);`}
                          >
                            <div class="absolute inset-0 bg-[radial-gradient(circle_at_18%_20%,rgba(255,255,255,0.92)_0%,rgba(255,255,255,0)_34%),radial-gradient(circle_at_80%_26%,rgba(255,255,255,0.55)_0%,rgba(255,255,255,0)_26%),radial-gradient(circle_at_58%_78%,rgba(255,255,255,0.36)_0%,rgba(255,255,255,0)_24%)]"></div>
                            <div class="relative flex h-full flex-col justify-between p-5 text-left text-[#2f2924]">
                              <p class="tiny-label text-[#6f635a]">{scent.visualFallback.eyebrow}</p>
                              <p class="body-copy mt-auto max-w-[12rem] text-[#51463d]">{scent.visualFallback.copy}</p>
                            </div>
                          </div>
                        )}
                      </div>
                    )}
                    <div class="p-5 pt-4">
                      <div class="rounded-[0.8rem] border p-4" style={`border-color: ${family.accent}4a; background: linear-gradient(135deg, rgba(255,255,255,0.92) 0%, ${family.accent}20 100%);`}>
                        <p class="body-copy text-[#4e4741]">{scent.storyCopy}</p>
                      </div>
                      <div class="mt-4 grid gap-3 lg:grid-cols-[minmax(0,1fr)_minmax(0,1.1fr)_180px]">
                        <article class="rounded-[0.8rem] border border-[#e8e0d8] bg-white/70 p-4">
                          <p class="tiny-label text-[#7a6b60]">How it smells</p>
                          <p class="body-copy mt-2 text-[#4e4741]">{scent.smell}.</p>
                        </article>
                        <article class="rounded-[0.8rem] border border-[#e8e0d8] bg-white/70 p-4">
                          <p class="tiny-label text-[#7a6b60]">Key notes</p>
                          <p class="body-copy mt-2 text-[#4e4741]">{scent.notes}.</p>
                        </article>
                        <article
                          class="rounded-[0.8rem] border p-4"
                          style={`border-color: ${family.accent}; background: linear-gradient(135deg, rgba(255,255,255,0.96) 0%, ${family.accent}22 100%);`}
                        >
                          <p class="tiny-label text-[#7a6b60]">Size</p>
                          <p class="body-copy mt-2 text-[#3f352f]">{scent.size}.</p>
                        </article>
                      </div>
                    </div>
                  </div>
                </article>
              ))}
            </div>

            <div class="grid gap-4 md:grid-cols-3">
              <article class="rounded-[0.95rem] border border-[#e7dfd8] bg-white/80 p-5 shadow-[0_10px_24px_rgba(56,39,27,0.035)]">
                <h3 class="section-title font-semibold tracking-[-0.02em] text-[#2f2924]">Customer cues</h3>
                <ul class="body-list mt-4 list-disc space-y-2 pl-5 text-[#4e4741] marker:text-[#605248]">
                  {family.customerCues.map((cue) => <li>{formatBulletText(cue)}</li>)}
                </ul>
              </article>
              <article class="rounded-[0.95rem] border border-[#c9bfaa] p-5" style={`background: linear-gradient(135deg, rgba(255,255,255,0.96) 0%, ${family.accent}26 100%);`}>
                <div class="section-title flex items-center gap-2 font-semibold tracking-[-0.02em] text-[#6e6054]">
                  <img src={topTipIcon} alt="" aria-hidden="true" class="w-auto shrink-0" style="height:1.1em;" />
                  <p class="leading-none">How to talk about it</p>
                </div>
                <ul class="body-list mt-4 list-disc space-y-2 pl-5 text-[#4e4741] marker:text-[#605248]">
                  {family.talkTrack.map((line) => <li>{formatBulletText(line)}</li>)}
                </ul>
              </article>
              <article class="rounded-[0.95rem] border border-transparent p-5 text-white" style={`background: linear-gradient(135deg, ${family.deep} 0%, ${family.accent} 100%);`}>
                <p class="inline-flex rounded-full bg-white/18 px-4 py-2 text-sm font-semibold">When to recommend</p>
                <p class="body-copy mt-4 text-white/95">{family.whenToRecommend}</p>
              </article>
            </div>
          </div>
        </section>
      ))}

      <section
        id="sell"
        class="mt-6 overflow-hidden rounded-[1rem] border shadow-[0_14px_36px_rgba(56,39,27,0.05)]"
        style={`border-color: ${sellingGuide.accent}; background: linear-gradient(180deg, ${sellingGuide.soft} 0%, #fff 24%, #fff 100%);`}
      >
        <div class="px-4 py-8 md:px-8" style={`background: linear-gradient(135deg, #efe1d4 0%, ${sellingGuide.accent} 100%);`}>
          <p class="text-sm font-semibold uppercase tracking-[0.18em] text-[#6e6054]">{sellingGuide.lesson}</p>
          <h2 class="section-title mt-3 font-semibold tracking-[-0.03em] text-[#2f2924]">{sellingGuide.title}</h2>
        </div>

        <div class="space-y-6 px-4 py-6 md:px-8 md:py-8">
          <div class="rounded-[0.95rem] border border-[#e7dfd8] bg-white p-5">
            <div class="body-copy space-y-4 text-[#4e4741]">
              {sellingGuide.summary.map((paragraph) => <p>{paragraph}</p>)}
            </div>
          </div>

          <div class="grid gap-4 md:grid-cols-2">
            <article class="rounded-[0.95rem] border border-[#c9bfaa] p-5" style={`background: linear-gradient(135deg, rgba(255,255,255,0.96) 0%, ${sellingGuide.accent}26 100%);`}>
              <h3 class="section-title font-semibold tracking-[-0.02em] text-[#2f2924]">Simple sales flow</h3>
              <ul class="body-list mt-4 list-disc space-y-2 pl-5 text-[#4e4741] marker:text-[#605248]">
                {sellingGuide.flow.map((step) => <li>{formatBulletText(step)}</li>)}
              </ul>
            </article>
            <article class="rounded-[0.95rem] border border-[#eaded4] bg-[linear-gradient(180deg,rgba(255,255,255,0.98)_0%,#fff5ef_100%)] p-5 shadow-[0_10px_24px_rgba(56,39,27,0.035)]">
              <div class="section-title flex items-center gap-2 font-semibold tracking-[-0.02em] text-[#6e6054]">
                <img src={topTipIcon} alt="" aria-hidden="true" class="w-auto shrink-0" style="height:1.1em;" />
                <p class="leading-none">Usage tips to share</p>
              </div>
              <ul class="body-list mt-4 list-disc space-y-2 pl-5 text-[#4e4741] marker:text-[#605248]">
                {sellingGuide.usageTips.map((tip) => <li>{formatBulletText(tip)}</li>)}
              </ul>
            </article>
          </div>

          <div class="grid gap-4 md:grid-cols-2">
            {sellingGuide.phrases.map((phrase) => (
              <article class="rounded-[0.95rem] bg-white/60 p-5 shadow-[0_10px_24px_rgba(56,39,27,0.035)]">
                <h3 class="section-title font-semibold tracking-[-0.02em] text-[#2f2924]">{phrase.title}</h3>
                <ul class="body-list mt-4 list-disc space-y-2 pl-5 text-[#4e4741] marker:text-[#605248]">
                  {phrase.bullets.map((bullet) => <li>{formatBulletText(bullet)}</li>)}
                </ul>
              </article>
            ))}
          </div>

          <div class="grid gap-4 md:grid-cols-2">
            {sellingGuide.sizes.map((size) => (
              <article class="rounded-[0.95rem] border border-[#eaded4] bg-white/80 p-5 shadow-[0_10px_24px_rgba(56,39,27,0.035)]">
                <h3 class="section-title font-semibold tracking-[-0.02em] text-[#2f2924]">{size.title}</h3>
                <ul class="body-list mt-4 list-disc space-y-2 pl-5 text-[#4e4741] marker:text-[#605248]">
                  {size.bullets.map((bullet) => <li>{formatBulletText(bullet)}</li>)}
                </ul>
              </article>
            ))}
          </div>

          <div class="grid gap-4 md:grid-cols-3">
            {sellingGuide.scenarios.map((scenario) => (
              <article class="rounded-[0.95rem] border border-transparent p-5 text-white" style={`background: linear-gradient(135deg, ${sellingGuide.deep} 0%, ${sellingGuide.accent} 100%);`}>
                <p class="inline-flex rounded-full bg-white/18 px-4 py-2 text-sm font-semibold">{scenario.title}</p>
                <p class="body-copy mt-4 text-white/95"><strong>Customer:</strong> {scenario.customer}</p>
                <p class="body-copy mt-4 text-white/95"><strong>Best response:</strong> {scenario.response}</p>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section
        id="matcher"
        class="mt-6 overflow-hidden rounded-[1rem] border shadow-[0_14px_36px_rgba(56,39,27,0.08)]"
        style="border-color: #9b7563; background: linear-gradient(180deg, #f5ece5 0%, #fff 24%, #fff 100%);"
        data-mood-matcher
      >
        <div class="bg-[linear-gradient(135deg,#332a25_0%,#8d7260_100%)] px-4 py-8 text-white md:px-8">
          <p class="text-sm font-semibold uppercase tracking-[0.18em] text-white/70">{moodMatcher.lesson}</p>
          <h2 class="section-title mt-3 font-semibold tracking-[-0.03em] text-white">{moodMatcher.title}</h2>
          <p class="body-copy mt-4 max-w-3xl text-white/85">{moodMatcher.intro}</p>
        </div>

        <div class="space-y-6 px-4 py-6 md:px-8 md:py-8">
          <div class="grid gap-4 lg:grid-cols-[minmax(0,0.95fr)_minmax(0,1.05fr)]">
            <article class="rounded-[0.95rem] border border-[#e0d0c5] bg-white p-5 shadow-[0_10px_24px_rgba(56,39,27,0.035)]">
              <div class="flex flex-wrap items-center justify-between gap-3">
                <h3 class="section-title font-semibold tracking-[-0.02em] text-[#2f2924]">Step 1: pick a mood</h3>
                <button
                  type="button"
                  data-matcher-reset
                  class="rounded-full border border-[#ddccc0] bg-[#faf5f0] px-4 py-2 text-sm font-medium text-[#5d5047] transition hover:bg-white"
                >
                  Start again
                </button>
              </div>
              <div class="mt-4 grid gap-3 sm:grid-cols-2">
                {moodMatcher.moods.map((mood) => (
                  <button
                    type="button"
                    data-matcher-mood={mood.id}
                    data-label={mood.label}
                    data-selected="false"
                    aria-pressed="false"
                    class="matcher-button rounded-[0.9rem] border border-transparent px-4 py-4 text-left transition"
                    style={`background: linear-gradient(135deg, ${mood.soft} 0%, ${mood.accent} 100%);`}
                  >
                    <span class="flex items-start justify-between gap-3">
                      <span class="block text-sm font-semibold uppercase tracking-[0.16em] text-[#5f544b]">Mood</span>
                      <span aria-hidden="true" class="matcher-selected-pill">&#10003;</span>
                    </span>
                    <span class="mt-3 block text-[1.125rem] font-semibold leading-7 text-[#2f2924]">{mood.label}</span>
                  </button>
                ))}
              </div>
            </article>

            <article class="rounded-[0.95rem] border border-[#e0d0c5] bg-white p-5 shadow-[0_10px_24px_rgba(56,39,27,0.035)]">
              <h3 class="section-title font-semibold tracking-[-0.02em] text-[#2f2924]">Step 2: pick the moment</h3>
              <div class="mt-4 grid gap-3 sm:grid-cols-3">
                {moodMatcher.moments.map((moment) => (
                  <button
                    type="button"
                    data-matcher-moment={moment.id}
                    data-label={moment.label}
                    data-selected="false"
                    aria-pressed="false"
                    class="matcher-moment-button rounded-[0.9rem] border border-[#e0d0c5] bg-[#faf5f0] px-4 py-4 text-left transition"
                  >
                    <span class="flex items-start justify-between gap-3">
                      <span class="block text-sm font-semibold uppercase tracking-[0.16em] text-[#7a6b60]">Moment</span>
                      <span aria-hidden="true" class="matcher-selected-pill">&#10003;</span>
                    </span>
                    <span class="mt-3 block text-[1.125rem] font-semibold leading-7 text-[#2f2924]">{moment.label}</span>
                  </button>
                ))}
              </div>

              <div class="mt-6 rounded-[0.9rem] border border-[#dfcfc3] bg-[linear-gradient(135deg,#faf4ee_0%,#fff_100%)] p-4">
                <p class="tiny-label text-[#7a6b60]">Current match</p>
                <p class="body-copy mt-2 text-[#3f352f]">
                  <span data-matcher-current-mood>Choose a mood</span>
                  <span class="px-2 text-[#8f7968]">+</span>
                  <span data-matcher-current-moment>choose a moment</span>
                </p>
                <p class="mt-2 text-sm leading-6 text-[#6a5e56]">Use this final activity to practise landing on one lead scent and one backup option with confidence.</p>
              </div>
            </article>
          </div>

          <article data-matcher-empty class="rounded-[0.95rem] border border-dashed border-[#d5c2b6] bg-[linear-gradient(135deg,rgba(255,255,255,0.96)_0%,#f8efe8_100%)] p-5">
            <h3 class="section-title font-semibold tracking-[-0.02em] text-[#2f2924]">Make a match</h3>
            <p class="body-copy mt-2 text-[#4e4741]">Choose one mood and one moment to reveal the best fragrance to lead with, plus a backup option.</p>
          </article>

          <div class="grid gap-4">
            {moodMatcher.matches.map((match) => (
              <article
                data-matcher-result
                data-mood={match.mood}
                data-moment={match.moment}
                hidden
                class="matcher-result overflow-hidden rounded-[0.95rem] border border-[#ddd0c2] bg-white"
              >
                <div class="grid gap-4 p-5 lg:grid-cols-[minmax(0,1.08fr)_minmax(0,0.92fr)] lg:p-6">
                <div
                  class="rounded-[0.9rem] border p-5"
                  style={`border-color: ${moodMatcherMoodById[match.mood].accent}; background: linear-gradient(135deg, rgba(255,255,255,0.96) 0%, ${moodMatcherMoodById[match.mood].accent}30 100%);`}
                >
                  <p class="tiny-label text-[#7a6b60]">{moodMatcherMoodById[match.mood].label} match</p>
                  <h3 class="product-title mt-3 font-semibold tracking-[-0.03em] text-[#2f2924]">{match.lead}</h3>
                  <p class="body-copy mt-3 text-[#4e4741]">{match.why}</p>
                  <div class="mt-5 rounded-[0.8rem] bg-white/72 p-4">
                      <p class="tiny-label text-[#7a6b60]">How to sell it</p>
                      <p class="body-copy mt-2 text-[#4e4741]">{match.sell}</p>
                  </div>
                </div>

                <div class="grid gap-4">
                  <article class="rounded-[0.9rem] border border-[#ece4dc] bg-[#faf7f4] p-5">
                      <p class="tiny-label text-[#7a6b60]">Backup option</p>
                      <p class="product-title mt-3 font-semibold tracking-[-0.02em] text-[#2f2924]">{match.backup}</p>
                      <p class="body-copy mt-2 text-[#4e4741]">Keep this ready if the shopper wants something close, but slightly different.</p>
                  </article>

                  <article class="rounded-[0.9rem] border border-[#ece4dc] bg-white p-5">
                      <p class="tiny-label text-[#7a6b60]">Go deeper</p>
                      <p class="body-copy mt-2 text-[#4e4741]">Jump into the full family section for more cues, talk tracks, and product detail.</p>
                      <a
                        href={`#${match.family}`}
                        class="mt-4 inline-flex items-center rounded-full border border-[#ddd2c8] bg-[#f7f3ef] px-4 py-2 text-sm font-medium text-[#4f443d] transition hover:bg-white"
                      >
                        Open {moodMatcherMoodById[match.mood].label}
                      </a>
                    </article>
                  </div>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>
    </main>
    <script>
      const mobileNavs = document.querySelectorAll("[data-mobile-nav]");

      document.addEventListener("click", (event) => {
        mobileNavs.forEach((menu) => {
          if (!menu.contains(event.target)) {
            menu.removeAttribute("open");
          }
        });
      });

      mobileNavs.forEach((menu) => {
        menu.querySelectorAll("[data-mobile-nav-link]").forEach((link) => {
          link.addEventListener("click", () => {
            menu.removeAttribute("open");
          });
        });
      });

      (() => {
        const root = document.querySelector("[data-mood-matcher]");

        if (!root) return;

        const moodButtons = Array.from(root.querySelectorAll("[data-matcher-mood]"));
        const momentButtons = Array.from(root.querySelectorAll("[data-matcher-moment]"));
        const results = Array.from(root.querySelectorAll("[data-matcher-result]"));
        const emptyState = root.querySelector("[data-matcher-empty]");
        const currentMood = root.querySelector("[data-matcher-current-mood]");
        const currentMoment = root.querySelector("[data-matcher-current-moment]");
        const resetButton = root.querySelector("[data-matcher-reset]");

        let selectedMood = null;
        let selectedMoment = null;

        const applyButtonState = (buttons, selectedValue, attributeName) => {
          buttons.forEach((button) => {
            const isSelected = button.getAttribute(attributeName) === selectedValue;
            button.dataset.selected = String(isSelected);
            button.setAttribute("aria-pressed", String(isSelected));
          });
        };

        const updateResults = () => {
          const hasMatch = Boolean(selectedMood && selectedMoment);

          if (emptyState) {
            emptyState.hidden = hasMatch;
          }

          if (currentMood) {
            currentMood.textContent =
              moodButtons.find((button) => button.getAttribute("data-matcher-mood") === selectedMood)?.getAttribute("data-label") ||
              "Choose a mood";
          }

          if (currentMoment) {
            currentMoment.textContent =
              momentButtons.find((button) => button.getAttribute("data-matcher-moment") === selectedMoment)?.getAttribute("data-label") ||
              "choose a moment";
          }

          results.forEach((result) => {
            const isMatch =
              hasMatch &&
              result.getAttribute("data-mood") === selectedMood &&
              result.getAttribute("data-moment") === selectedMoment;

            result.hidden = !isMatch;
          });
        };

        moodButtons.forEach((button) => {
          button.addEventListener("click", () => {
            selectedMood = button.getAttribute("data-matcher-mood");
            applyButtonState(moodButtons, selectedMood, "data-matcher-mood");
            updateResults();
          });
        });

        momentButtons.forEach((button) => {
          button.addEventListener("click", () => {
            selectedMoment = button.getAttribute("data-matcher-moment");
            applyButtonState(momentButtons, selectedMoment, "data-matcher-moment");
            updateResults();
          });
        });

        resetButton?.addEventListener("click", () => {
          selectedMood = null;
          selectedMoment = null;
          applyButtonState(moodButtons, selectedMood, "data-matcher-mood");
          applyButtonState(momentButtons, selectedMoment, "data-matcher-moment");
          updateResults();
        });

        updateResults();
      })();
    </script>
    <style>
      .hero-title {
        font-size: 2rem;
        line-height: 1.08;
      }

      .section-title {
        font-size: 1.5rem;
        line-height: 1.35;
      }

      .product-title {
        font-size: 1.5rem;
        line-height: 2.1875rem;
        text-align: left;
      }

      .body-copy,
      .body-list {
        font-size: 1.125rem;
        line-height: 2rem;
      }

      .tiny-label {
        font-size: 0.75rem;
        font-weight: 600;
        letter-spacing: 0.16em;
        line-height: 1rem;
        text-transform: uppercase;
      }

      .product-media {
        align-self: start;
      }

      .product-image-frame {
        aspect-ratio: 1 / 1;
      }

      @media (min-width: 768px) {
        .hero-title {
          font-size: 2.25rem;
        }
      }

      .matcher-button,
      .matcher-moment-button {
        position: relative;
        overflow: hidden;
        transition:
          transform 180ms ease,
          box-shadow 180ms ease,
          border-color 180ms ease,
          background-color 180ms ease,
          color 180ms ease;
      }

      .matcher-button:hover,
      .matcher-moment-button:hover {
        transform: translateY(-1px);
      }

      .matcher-selected-pill {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border: 1px solid rgba(47, 41, 36, 0.14);
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.76);
        color: #2f2924;
        font-size: 0.82rem;
        font-weight: 700;
        line-height: 1;
        min-height: 1.65rem;
        min-width: 1.65rem;
        opacity: 0;
        padding: 0.2rem;
        transform: translateY(-6px);
        transition:
          opacity 180ms ease,
          transform 180ms ease,
          background-color 180ms ease,
          color 180ms ease,
          border-color 180ms ease;
      }

      .matcher-button[data-selected="true"] .matcher-selected-pill,
      .matcher-moment-button[data-selected="true"] .matcher-selected-pill {
        opacity: 1;
        transform: translateY(0);
      }

      .matcher-button[data-selected="true"] {
        border-color: #2f2924;
        box-shadow:
          0 0 0 3px rgba(47, 41, 36, 0.12),
          0 18px 30px rgba(56, 39, 27, 0.16);
        transform: translateY(-2px) scale(1.01);
      }

      .matcher-button[data-selected="true"] .matcher-selected-pill {
        background: rgba(47, 41, 36, 0.92);
        border-color: rgba(47, 41, 36, 0.92);
        color: #fff;
      }

      .matcher-moment-button[data-selected="true"] {
        background: linear-gradient(135deg, #2f2924 0%, #5b4a40 100%);
        border-color: #2f2924;
        color: #fff;
        box-shadow:
          0 0 0 3px rgba(47, 41, 36, 0.12),
          0 18px 30px rgba(56, 39, 27, 0.18);
        transform: translateY(-2px) scale(1.01);
      }

      .matcher-moment-button[data-selected="true"] span {
        color: inherit;
      }

      .matcher-moment-button[data-selected="true"] .matcher-selected-pill {
        background: rgba(255, 255, 255, 0.16);
        border-color: rgba(255, 255, 255, 0.24);
        color: #fff;
      }

      .matcher-result {
        animation: matcher-rise 240ms ease;
      }

      @keyframes matcher-rise {
        from {
          opacity: 0;
          transform: translateY(10px);
        }

        to {
          opacity: 1;
          transform: translateY(0);
        }
      }
    </style>
  </body>
</html>
