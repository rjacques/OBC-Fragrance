---
const { name, class: className = "" } = Astro.props;

const icons = {
  box: [
    { tag: "path", attrs: { d: "M4 7.5 12 3l8 4.5v9L12 21l-8-4.5z" } },
    { tag: "path", attrs: { d: "M4 7.5 12 12l8-4.5" } },
    { tag: "path", attrs: { d: "M12 12v9" } },
  ],
  sparkles: [
    { tag: "path", attrs: { d: "M12 4.5 13.7 8.3 17.5 10l-3.8 1.7L12 15.5l-1.7-3.8L6.5 10l3.8-1.7z" } },
    { tag: "path", attrs: { d: "M18.5 4.5v2" } },
    { tag: "path", attrs: { d: "M17.5 5.5h2" } },
    { tag: "path", attrs: { d: "M5.5 16.5v3" } },
    { tag: "path", attrs: { d: "M4 18h3" } },
