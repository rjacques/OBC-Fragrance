  tag: [
    { tag: "path", attrs: { d: "M11 4H5v6l8.5 8.5a1.5 1.5 0 0 0 2.1 0l4.9-4.9a1.5 1.5 0 0 0 0-2.1z" } },
    { tag: "circle", attrs: { cx: "7.5", cy: "7.5", r: "1.1" } },
  ],
  grid: [
    { tag: "rect", attrs: { x: "4", y: "4", width: "6.5", height: "6.5", rx: "1.2" } },
    { tag: "rect", attrs: { x: "13.5", y: "4", width: "6.5", height: "6.5", rx: "1.2" } },
    { tag: "rect", attrs: { x: "4", y: "13.5", width: "6.5", height: "6.5", rx: "1.2" } },
    { tag: "rect", attrs: { x: "13.5", y: "13.5", width: "6.5", height: "6.5", rx: "1.2" } },
  ],
  help: [
    { tag: "circle", attrs: { cx: "12", cy: "12", r: "8.5" } },
    { tag: "path", attrs: { d: "M9.8 9.3A2.4 2.4 0 0 1 12 8a2.5 2.5 0 0 1 2.5 2.4c0 1.6-1.6 2.2-2.3 2.9-.5.4-.7.8-.7 1.7" } },
    { tag: "circle", attrs: { cx: "12", cy: "17.3", r: "0.6" } },
  ],
  chat: [
    { tag: "path", attrs: { d: "M5.5 6.5h13a1.5 1.5 0 0 1 1.5 1.5v7a1.5 1.5 0 0 1-1.5 1.5H10l-4.5 3v-3H5.5A1.5 1.5 0 0 1 4 15V8a1.5 1.5 0 0 1 1.5-1.5Z" } },
    { tag: "path", attrs: { d: "M8 11h8" } },
    { tag: "path", attrs: { d: "M8 14h5" } },
  ],
  person: [
    { tag: "circle", attrs: { cx: "10", cy: "8.5", r: "2.8" } },
    { tag: "path", attrs: { d: "M4.8 18.5a5.7 5.7 0 0 1 10.4 0" } },
    { tag: "circle", attrs: { cx: "17.2", cy: "16.8", r: "2.3" } },
    { tag: "path", attrs: { d: "m19 18.6 1.9 1.9" } },
  ],
  check: [
    { tag: "circle", attrs: { cx: "12", cy: "12", r: "8.5" } },
    { tag: "path", attrs: { d: "m8.6 12.3 2.2 2.2 4.7-5" } },
  ],
  twinkle: [
    { tag: "path", attrs: { d: "M12 4.2 13.5 8 17.3 9.5 13.5 11 12 14.8 10.5 11 6.7 9.5 10.5 8z" } },
  ],
  leaf: [
    { tag: "path", attrs: { d: "M18.8 5.5c-6.1.1-10 2.3-11.8 6.6-1 2.5-.9 4.8-.8 6.4 1.5.2 3.8.3 6.3-.7 4.4-1.7 6.7-5.7 6.8-12.3Z" } },
    { tag: "path", attrs: { d: "M8 16c2.3-1.9 5-3.7 8.2-5.2" } },
  ],
  ruler: [
    { tag: "rect", attrs: { x: "4", y: "7", width: "16", height: "10", rx: "1.5" } },
    { tag: "path", attrs: { d: "M8 7v3" } },
    { tag: "path", attrs: { d: "M11 7v2" } },
    { tag: "path", attrs: { d: "M14 7v3" } },
    { tag: "path", attrs: { d: "M17 7v2" } },
  ],
  shop: [
    { tag: "path", attrs: { d: "M5 9.2 6.3 5h11.4L19 9.2" } },
    { tag: "path", attrs: { d: "M4.5 9.2h15v2.2A2.3 2.3 0 0 1 17.2 13 2.6 2.6 0 0 1 15 11.8 2.6 2.6 0 0 1 12 13a2.6 2.6 0 0 1-3-1.2A2.6 2.6 0 0 1 6.8 13a2.3 2.3 0 0 1-2.3-1.6Z" } },
    { tag: "path", attrs: { d: "M6.5 13v6.5h11V13" } },
    { tag: "path", attrs: { d: "M10 19.5V16h4v3.5" } },
  ],
  bulb: [
    { tag: "path", attrs: { d: "M9.2 17.4h5.6" } },
    { tag: "path", attrs: { d: "M10 20h4" } },
    { tag: "path", attrs: { d: "M8.8 14.8c-1.5-1.1-2.5-2.8-2.5-4.8a5.7 5.7 0 1 1 11.4 0c0 2-1 3.7-2.5 4.8-.7.5-1.1 1.2-1.1 2H10c0-.8-.4-1.5-1.2-2Z" } },
  ],
  bag: [
    { tag: "path", attrs: { d: "M7 8.5V7a5 5 0 0 1 10 0v1.5" } },
    { tag: "path", attrs: { d: "M5.5 8.5h13l-1 10.5H6.5Z" } },
    { tag: "path", attrs: { d: "M9.5 11.8v.2" } },
    { tag: "path", attrs: { d: "M14.5 11.8v.2" } },
  ],
};

const icon = icons[name] ?? icons.sparkles;
---

<svg
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.8"
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
  aria-hidden="true"
>
  {icon.map((shape) =>
    shape.tag === "circle" ? (
      <circle {...shape.attrs} />
    ) : shape.tag === "rect" ? (
      <rect {...shape.attrs} />
    ) : (
      <path {...shape.attrs} />
    )
  )}
</svg>
