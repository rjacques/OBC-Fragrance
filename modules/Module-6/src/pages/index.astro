---
import "../styles/global.css";
import courseHero from "../images/mod-6-hero.jpg";
import topTipIcon from "../images/top-tip.svg?url";

function svgToDataUri(svg) {
  return `data:image/svg+xml;charset=utf-8,${encodeURIComponent(svg)}`;
}

const TFG_LOGO = svgToDataUri(`
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 56.7 56.7">
  <rect width="56.7" height="56.7" fill="#6C2C84"/>
  <path fill="#FFFFFF" d="M41.1,12V8.5h-9.6v19c-1-0.3-2.1-0.5-3.2-0.5c-1.3,0-2.4,0.2-3.5,0.5V12h5.4V8.5H15.6V12H21v17.6l0,0 c-0.2,0.2-0.5,0.4-0.7,0.6c-2.1,2.1-3.2,4.6-3.2,7.6s1,5.5,3.1,7.5s4.6,3.1,7.6,3.1s5.5-1.1,7.5-3.2c0.9-1,1.5-2,1.8-3.1 c0.4-1.2,0.6-2.6,0.6-4.1v-0.7h-9.7v2.9h6.2c-0.2,1.5-0.8,2.7-2.1,3.7c-1.2,1-2.6,1.3-4.2,1.3c-1.8,0-3.5-0.7-5.1-2.1 c-1.7-1.5-2.3-3.2-2.3-5.5s0.5-4.1,2-5.6c1.5-1.5,3.4-2,5.6-2c1.8,0,3.4,0.4,4.8,1.5l2-2.3v-9.1h4v-3h-4V12L41.1,12L41.1,12z"/>
</svg>
`);

const OBC_LOGO = svgToDataUri(`
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 152.747 156.044">
  <g>
    <g>
      <path d="M24.992,137.978c0,2.421-1.769,3.804-5.286,3.804h-6.472v-14.24h6.07c3.136,0,4.945,1.343,4.945,3.662,0,1.627-.864,2.706-2.151,3.234,1.809.407,2.894,1.607,2.894,3.54ZM14.72,128.783v5.167h4.482c2.251,0,3.558-.875,3.558-2.584s-1.307-2.584-3.558-2.584h-4.482ZM23.504,137.856c0-1.851-1.347-2.665-3.819-2.665h-4.965v5.35h4.965c2.472,0,3.819-.814,3.819-2.685Z"/>
      <path d="M39.247,140.48v1.302h-9.992v-14.24h9.689v1.302h-8.196v5.065h7.307v1.282h-7.307v5.289h8.498Z"/>
      <path d="M52.467,137.978h-7.99l-1.721,3.804h-1.577l6.556-14.24h1.496l6.556,14.24h-1.598l-1.721-3.804ZM51.914,136.757l-3.442-7.649-3.442,7.649h6.884Z"/>
      <path d="M58.502,135.63v-8.088h1.498v8.028c0,3.348,1.579,4.881,4.332,4.881,2.773,0,4.352-1.533,4.352-4.881v-8.028h1.458v8.088c0,4.054-2.186,6.152-5.81,6.152s-5.83-2.098-5.83-6.152Z"/>
      <path d="M78.252,128.844h-5.023v-1.302h11.557v1.302h-5.023v12.938h-1.511v-12.938Z"/>
      <path d="M92.75,136.859v4.923h-1.457v-4.923l-5.588-9.317h1.577l4.79,7.995,4.79-7.995h1.477l-5.588,9.317Z"/>
      <path d="M106.378,134.603c0-4.134,3.12-7.18,7.341-7.18,2.04,0,3.88.686,5.121,2.057l-.94.948c-1.14-1.17-2.54-1.674-4.14-1.674-3.38,0-5.921,2.501-5.921,5.849s2.54,5.849,5.921,5.849c1.6,0,3-.504,4.14-1.694l.94.948c-1.24,1.371-3.08,2.077-5.141,2.077-4.2,0-7.321-3.045-7.321-7.18Z"/>
      <path d="M121.653,134.603c0-4.082,3.145-7.124,7.418-7.124,4.233,0,7.398,3.022,7.398,7.124s-3.165,7.124-7.398,7.124c-4.273,0-7.418-3.042-7.418-7.124ZM134.978,134.603c0-3.342-2.52-5.804-5.906-5.804-3.407,0-5.947,2.461-5.947,5.804s2.54,5.804,5.947,5.804c3.386,0,5.906-2.461,5.906-5.804Z"/>
      <path d="M137.625,140.687c0-.616.477-1.073,1.053-1.073s1.073.457,1.073,1.073-.497,1.092-1.073,1.092-1.053-.477-1.053-1.092Z"/>
    </g>
    <path d="M97.622,24.927c-6.633-7.834-15.492-11.269-25.452-10.521-29.598,2.225-32.603,40.259-28.842,62.609,3.609,18.2,14.904,35.698,35.919,34.276-15.234,1.412-30.684-5.384-40.224-17.564-7.126-9.097-10.342-19.746-10.333-31.223.011-14.508,5.676-28.578,16.859-37.938,12.827-10.736,30.255-13.188,45.994-7.76,13.513,4.661,24.062,15.191,28.71,28.952,4.761,14.095,3.143,30.366-4.175,43.38-7.519,13.372-21.615,21.687-36.88,22.178,14.489-1.326,22.962-10.378,27.239-23.833,5.57-19.498,4.89-46.371-8.815-62.559Z"/>
  </g>
</svg>
`);

const navItems = [
  { href: "#wrap-up", label: "Wrap-up" },
  { href: "#final-tip", label: "Final tip" },
  { href: "#download", label: "Product info" },
];

const wrapUp = {
  label: "Course wrap-up",
  title: "You're ready to consult with confidence",
  intro: [
    "You've reached the end of this course - well done.",
    "You now have the product knowledge, language, and confidence to support customers across the O Beauty Co make-up range.",
  ],
  finalTipTitle: "One final tip",
  finalTipIntro: "When in doubt, keep it simple:",
  finalTipQuestions: [
    "What does it do?",
    "Who is it for?",
    "How will it help this customer today?",
  ],
  finalTipClose: "If you can answer those three questions, you're already doing a great consult.",
  closing: "You're ready. Go help customers feel confident, comfortable, and cared for - one product at a time.",
  downloadLabel: "Download the product information here",
};

const sectionPadding = "px-4 py-5 md:px-8 md:py-8 lg:px-10";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Module 6 | Course wrap-up: You're ready to consult with confidence</title>
  </head>
  <body class="bg-[#f4f1ed] text-[#27211c] selection:bg-[#d8c4b4] selection:text-[#241d18]">
    <main class="mx-auto max-w-[1240px] px-3 py-3 md:px-6 md:py-6">
      <header class="sticky top-3 z-30 rounded-[0.9rem] border border-[#e6dfd8] bg-white/94 px-3 py-3 shadow-[0_10px_26px_rgba(56,37,24,0.05)] backdrop-blur md:px-6">
        <div class="flex items-center justify-between gap-3 md:hidden">
          <div class="flex min-w-0 items-center gap-3">
            <img src={TFG_LOGO} alt="TFG logo" class="h-10 w-10 shrink-0" />
            <p class="min-w-0 text-sm font-medium leading-5 text-[#51463d]">Course wrap-up: You're ready to consult with confidence</p>
          </div>

          <details class="relative shrink-0 md:hidden" data-mobile-nav>
            <summary class="flex h-11 w-11 cursor-pointer list-none items-center justify-center rounded-full border border-[#e8e0d8] bg-[#faf8f6] text-[#51463d] transition hover:bg-[#f4efea] [&::-webkit-details-marker]:hidden">
              <span class="sr-only">Toggle navigation</span>
              <span aria-hidden="true" class="flex flex-col gap-[0.28rem]">
                <span class="block h-[2px] w-5 rounded-full bg-current"></span>
                <span class="block h-[2px] w-5 rounded-full bg-current"></span>
                <span class="block h-[2px] w-5 rounded-full bg-current"></span>
              </span>
            </summary>

            <div class="absolute right-0 top-[calc(100%+0.75rem)] z-20 w-64 max-w-[calc(100vw-1.5rem)] overflow-hidden rounded-[0.9rem] border border-[#e6dfd8] bg-white p-2 shadow-[0_14px_36px_rgba(56,39,27,0.09)]">
              <div class="flex flex-col gap-1.5 text-sm text-[#51463d]">
                {navItems.map((item) => (
                  <a href={item.href} class="rounded-[0.75rem] px-4 py-3 transition hover:bg-[#f4efea]" data-mobile-nav-link>{item.label}</a>
                ))}
              </div>
            </div>
          </details>
        </div>

        <div class="hidden md:flex md:items-center md:justify-between md:gap-6">
          <div class="flex items-center gap-4">
            <img src={TFG_LOGO} alt="TFG logo" class="h-10 w-10" />
            <p class="text-sm font-medium text-[#51463d]">Course wrap-up: You're ready to consult with confidence</p>
          </div>
          <div class="flex flex-wrap gap-2 text-sm text-[#51463d]">
            {navItems.map((item) => (
              <a href={item.href} class="rounded-full border border-[#e8e0d8] bg-[#faf8f6] px-4 py-2 hover:bg-[#f4efea]">{item.label}</a>
            ))}
          </div>
        </div>
      </header>

      <section class="relative mt-4 overflow-hidden rounded-[1rem] border border-[#e3ddd7] bg-[#f6f1ec] shadow-[0_14px_36px_rgba(56,39,27,0.05)]">
        <img src={courseHero.src} alt="Beauty course hero image" class="absolute inset-0 h-full w-full object-cover object-center md:inset-y-0 md:left-auto md:right-0 md:w-[50%] md:object-right" />
        <div class="absolute inset-0 bg-[linear-gradient(180deg,_rgba(246,241,236,0.6)_0%,_rgba(246,241,236,1)_100%)] md:inset-y-0 md:left-auto md:right-[10%] md:w-[40%] md:bg-[linear-gradient(90deg,_#f6f1ec_0%,_rgba(246,241,236,0)_100%)]"></div>
        <div class={`relative ${sectionPadding} md:py-20 lg:py-24`}>
          <img src={OBC_LOGO} alt="Beauty Co. logo" class="h-[4.8rem] w-auto md:h-24" />
          <div class="mt-6 inline-flex items-center gap-3 rounded-full border border-[#e6ddd5] bg-white/88 px-4 py-2 backdrop-blur md:mt-8">
            <span class="text-xs font-semibold uppercase tracking-[0.22em] text-[#8f7968]">Module 6</span>
          </div>
          <h1 class="mt-10 max-w-[42rem] text-4xl font-semibold tracking-[-0.03em] text-[#2f2924] md:mt-12 md:text-6xl">Wrap-up</h1>
        </div>
      </section>

      <section class="mt-6 space-y-6">
        <article id="wrap-up" class:list={["rounded-[1rem] border border-[#e3ddd7] bg-[#fbfaf8] shadow-[0_14px_36px_rgba(56,39,27,0.05)]", sectionPadding]}>
          <h2 class="text-[30px] font-semibold leading-[1.15] tracking-[-0.03em] text-[#2f2924]">{wrapUp.title}</h2>
          <div class="mt-5 space-y-4 text-[1.125rem] leading-8 text-[#4e4741]">
            {wrapUp.intro.map((paragraph) => <p>{paragraph}</p>)}
          </div>
        </article>

        <article id="final-tip" class:list={["rounded-[0.95rem] border border-[#c9bfaa] text-[#2f2924]", sectionPadding]} style="background: linear-gradient(135deg, rgba(255,255,255,0.96) 0%, rgba(210,183,166,0.15) 100%);">
          <div class="flex items-center gap-2 text-[1.5rem] font-semibold tracking-[-0.02em] text-[#6e6054]">
            <img src={topTipIcon} alt="" aria-hidden="true" class="w-auto shrink-0" style="height:1.1em;" />
            <p class="leading-none">{wrapUp.finalTipTitle}</p>
          </div>
          <p class="mt-4 text-[1.125rem] leading-8 text-[#4e4741]">{wrapUp.finalTipIntro}</p>
          <ul class="mt-4 list-disc space-y-2 pl-5 text-[1.125rem] leading-8 text-[#4e4741] marker:text-[#605248]">
            {wrapUp.finalTipQuestions.map((question) => <li>{question}</li>)}
          </ul>
          <p class="mt-4 text-[18px] font-bold leading-8 text-[#4e4741]">{wrapUp.finalTipClose}</p>
        </article>

        <article class:list={["rounded-[0.95rem] border border-transparent text-white", sectionPadding]} style="background: linear-gradient(135deg, #8d7260 0%, #d2b7a6 100%);">
          <h3 class="text-[1.8rem] font-semibold leading-[1.2] tracking-[-0.03em] md:text-[2.2rem]">You're ready.</h3>
          <p class="mt-4 max-w-[54rem] text-[1.125rem] leading-8 text-white/95">{wrapUp.closing}</p>
          <div id="download" class="mt-6 inline-flex rounded-full border border-white/25 bg-white/12 px-5 py-3 text-sm font-semibold tracking-[0.02em] text-white">
            {wrapUp.downloadLabel}
          </div>
        </article>
      </section>
    </main>

    <script is:inline>
      const mobileNavs = document.querySelectorAll('[data-mobile-nav]');

      document.addEventListener('click', (event) => {
        mobileNavs.forEach((nav) => {
          if (!nav.contains(event.target)) {
            nav.removeAttribute('open');
          }
        });
      });

      document.querySelectorAll('[data-mobile-nav-link]').forEach((link) => {
        link.addEventListener('click', () => {
          const parentNav = link.closest('[data-mobile-nav]');
          parentNav?.removeAttribute('open');
        });
      });
    </script>
  </body>
</html>
